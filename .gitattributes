# ─────────────────────────────────────────────────────────────
# AI writes code and automatically clicks — .gitattributes
# Normalize line endings across Windows / macOS / Linux
# ─────────────────────────────────────────────────────────────

# 默认：仓库内统一使用 LF 换行
* text=auto eol=lf

# 文本源码显式声明 / Explicit text types
*.py     text eol=lf
*.pyi    text eol=lf
*.txt    text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.spec   text eol=lf
*.vbs    text eol=crlf
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf
.gitignore  text eol=lf
.gitattributes text eol=lf

# 二进制资源 / Binary assets（不要做行尾转换）
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.bmp    binary
*.exe    binary
*.dll    binary
*.zip    binary
*.pyc    binary
*.pyz    binary
*.pyz    binary
